{
  "name": "control-gastos",
  "version": "1.0.0",
  "description": "App de control de gastos personal",
  "main": "main.js",
  "author": "Gamasoft",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.gamasoft.gastoflow",
    "productName": "GastoFlow",
    "asar": true,
    "asarUnpack": [],
    "files": [
      "**/*",
      "!data/**/*",
      "!release/**/*",
      "!.git/**/*",
      "!**/*.md"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  }
}
